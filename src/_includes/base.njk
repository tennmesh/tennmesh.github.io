<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="keywords" content="MeshCore, LoRa, mesh network, off-grid, Tennessee, emergency communications">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/assets/images/tennmesh-icon-light.svg">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }} | {{ site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="website">
  <meta property="og:image" content="/assets/images/tennmesh-icon-light.svg">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Stylesheet -->
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  {% include "header.njk" %}

  <main>
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  <script>
    document.querySelectorAll('pre').forEach(function(pre) {
      var code = pre.querySelector('code') || pre;
      var lines = code.textContent.trim().split('\n').filter(function(l) { return l.trim(); });

      var block = document.createElement('div');
      block.className = 'code-block';

      lines.forEach(function(line) {
        var lineEl = document.createElement('div');
        lineEl.className = 'code-line';

        var codeEl = document.createElement('code');
        codeEl.textContent = line;

        var btn = document.createElement('button');
        btn.className = 'copy-line-btn';
        btn.textContent = 'Copy';
        btn.addEventListener('click', function() {
          navigator.clipboard.writeText(line).then(function() {
            btn.textContent = 'Copied!';
            btn.classList.add('copied');
            setTimeout(function() {
              btn.textContent = 'Copy';
              btn.classList.remove('copied');
            }, 2000);
          });
        });

        lineEl.appendChild(codeEl);
        lineEl.appendChild(btn);
        block.appendChild(lineEl);
      });

      pre.parentNode.replaceChild(block, pre);
    });
  </script>
</body>
</html>
